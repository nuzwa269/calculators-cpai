{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "fitness-calculators-mcp",
      "version": "0.1.0",
      "title": "Fitness Calculators"
    },
    "tools": [
      {
        "name": "list_calculators",
        "title": "List Calculators",
        "description": "List every fitness/nutrition calculator this app publishes, with its slug and web path.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "calculate_bmr",
        "title": "Calculate BMR",
        "description": "Calculate Basal Metabolic Rate (kcal/day) using the Mifflin-St Jeor formula.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "sex": {
              "type": "string",
              "enum": [
                "male",
                "female"
              ],
              "description": "Biological sex."
            },
            "weightKg": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Weight in kilograms."
            },
            "heightCm": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Height in centimeters."
            },
            "age": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991,
              "description": "Age in years."
            }
          },
          "required": [
            "sex",
            "weightKg",
            "heightCm",
            "age"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_tdee",
        "title": "Calculate TDEE",
        "description": "Calculate Total Daily Energy Expenditure (kcal/day) from Mifflin-St Jeor BMR and an activity level.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "sex": {
              "type": "string",
              "enum": [
                "male",
                "female"
              ]
            },
            "weightKg": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "heightCm": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "age": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "activity": {
              "type": "string",
              "enum": [
                "sedentary",
                "light",
                "moderate",
                "active",
                "very_active"
              ],
              "description": "Weekly activity level."
            }
          },
          "required": [
            "sex",
            "weightKg",
            "heightCm",
            "age",
            "activity"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_macros",
        "title": "Calculate Macros",
        "description": "Calculate daily calorie target and protein/fat/carbohydrate macros for a cut, maintenance, or bulk goal.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "tdee": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Total Daily Energy Expenditure in kcal/day."
            },
            "weightKg": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "goal": {
              "type": "string",
              "enum": [
                "cut",
                "maintain",
                "bulk"
              ]
            }
          },
          "required": [
            "tdee",
            "weightKg",
            "goal"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_protein",
        "title": "Calculate Daily Protein",
        "description": "Calculate a daily protein target (grams) based on bodyweight and goal.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "weightKg": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "goal": {
              "type": "string",
              "enum": [
                "fat_loss",
                "maintain",
                "muscle_gain"
              ]
            }
          },
          "required": [
            "weightKg",
            "goal"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_body_fat",
        "title": "Estimate Body Fat %",
        "description": "Estimate body fat percentage using the US Navy tape method. Requires hip circumference for females.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "sex": {
              "type": "string",
              "enum": [
                "male",
                "female"
              ]
            },
            "heightCm": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "neckCm": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "waistCm": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "hipCm": {
              "anyOf": [
                {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Hip circumference in cm. Required for female; pass null for male."
            }
          },
          "required": [
            "sex",
            "heightCm",
            "neckCm",
            "waistCm",
            "hipCm"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_one_rep_max",
        "title": "Estimate 1-Rep Max",
        "description": "Estimate one-rep max (1RM) from a lift's weight and rep count using the Epley and Brzycki formulas, plus a percentage table.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "weight": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Weight lifted (any unit; output uses same unit)."
            },
            "reps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 15,
              "description": "Reps performed (1-15)."
            }
          },
          "required": [
            "weight",
            "reps"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "calculate_water_intake",
        "title": "Daily Water Intake",
        "description": "Estimate daily water intake (ml, liters, cups, ounces) from bodyweight, activity minutes, and climate.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "weightKg": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "activityMin": {
              "type": "number",
              "minimum": 0,
              "description": "Minutes of physical activity per day."
            },
            "climate": {
              "type": "string",
              "enum": [
                "cool",
                "moderate",
                "hot"
              ]
            }
          },
          "required": [
            "weightKg",
            "activityMin",
            "climate"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
